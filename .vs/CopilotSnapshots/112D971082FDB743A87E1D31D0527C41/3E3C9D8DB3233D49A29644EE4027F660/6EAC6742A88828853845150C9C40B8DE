using Microsoft.EntityFrameworkCore;
using System.Diagnostics;
using SmartParking.Server.Data;
using Microsoft.AspNetCore.Authentication.JwtBearer;
using Microsoft.IdentityModel.Tokens;
using System.Text;
using Microsoft.OpenApi.Models;

var builder = WebApplication.CreateBuilder(args);

// Add services to the container.

// Database Configuration
// Prefer MySQL if a connection string is provided; otherwise fall back to In-Memory DB
var connectionString = builder.Configuration.GetConnectionString("DefaultConnection");
if (!string.IsNullOrWhiteSpace(connectionString))
{
    // If the connection string explicitly contains an empty password, avoid attempting AutoDetect
    // which will try to open a connection and fail. Fall back to InMemory in that case.
    var csLower = connectionString.ToLowerInvariant();
    var pwdEmpty = false;
    if (csLower.Contains("password=") || csLower.Contains("pwd="))
    {
        var m = System.Text.RegularExpressions.Regex.Match(connectionString, "(?:password|pwd)\\s*=\\s*([^;]*)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (m.Success)
        {
            pwdEmpty = string.IsNullOrEmpty(m.Groups[1].Value);
        }
    }

    if (pwdEmpty)
    {
        Console.WriteLine("Warning: DefaultConnection contains an empty password. Falling back to InMemory DB. Update appsettings.json with valid MySQL credentials to use MySQL.");
        builder.Services.AddDbContext<AppDbContext>(options =>
            options.UseInMemoryDatabase("SmartParkingDb"));
    }
    else
    {
        try
        {
            var serverVersion = ServerVersion.AutoDetect(connectionString);
            builder.Services.AddDbContext<AppDbContext>(options =>
                options.UseMySql(connectionString, serverVersion));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Warning: Could not connect to MySQL ({ex.Message}). Falling back to InMemory DB.");
            builder.Services.AddDbContext<AppDbContext>(options =>
                options.UseInMemoryDatabase("SmartParkingDb"));
        }
    }
}
else
{
    builder.Services.AddDbContext<AppDbContext>(options =>
        options.UseInMemoryDatabase("SmartParkingDb"));
}

